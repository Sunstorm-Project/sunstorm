#!/bin/sh
# SSTspcrd postinstall — CDE desktop integration for SPARCcord

DTDIR=/usr/dt/appconfig
TYPES="${DTDIR}/types/C"
ICONS="${DTDIR}/icons/C"

# Create CDE action definition
mkdir -p "${TYPES}" "${ICONS}"
cat > "${TYPES}/sparccord.dt" << 'DTEOF'
# SPARCcord — Motif/CDE Discord Client
# CDE Action and DataType definitions

ACTION Sparccord
{
    LABEL           SPARCcord
    TYPE            COMMAND
    EXEC_STRING     /opt/sparccord/bin/sparccord
    ICON            Spcrd
    WINDOW_TYPE     NO_STDIO
    DESCRIPTION     Motif/CDE Discord client via headless-Chrome bridge
}
DTEOF

