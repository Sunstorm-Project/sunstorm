#!/bin/sh
# SSTnsurf postinstall — CDE desktop integration for NetSurf
#
# Installs a CDE action in Desktop_Apps and optionally overrides
# the front panel WebBrowser action so NetSurf launches when the
# globe icon is clicked (replacing HotJava).

DTDIR=/usr/dt/appconfig
TYPES="${DTDIR}/types/C"
ICONS="${DTDIR}/icons/C"
BASEDIR=/opt/sst

# Create CDE action definition
mkdir -p "${TYPES}" "${ICONS}"
cat > "${TYPES}/netsurf.dt" << 'DTEOF'
# NetSurf — Lightweight Web Browser for Solaris 7
# CDE Action and DataType definitions

ACTION Netsurf
{
    LABEL           NetSurf Web Browser
    TYPE            COMMAND
    EXEC_STRING     /opt/sst/bin/netsurf "%Arg_1%"
    ICON            Nsurf
    WINDOW_TYPE     NO_STDIO
    DESCRIPTION     Lightweight web browser with HTML5/CSS3 support. \
                    Supports PNG, JPEG, SVG, and HTTPS via libcurl.
}

# Override the CDE front panel WebBrowser action.
# When this file is installed, clicking the globe icon on the front
# panel launches NetSurf instead of HotJava.  Remove this file (or
# the package) to restore the original behaviour.

ACTION WebBrowser
{
    LABEL           Web Browser
    TYPE            COMMAND
    EXEC_STRING     /opt/sst/bin/netsurf "%Arg_1%"
    ICON            SDtwebbr
    WINDOW_TYPE     NO_STDIO
    DESCRIPTION     NetSurf web browser (replaces HotJava)
}

# ---- DataType for HTML files opened via NetSurf ----

ACTION Open
{
    LABEL           Open in NetSurf
    ARG_TYPE        HTML
    TYPE            COMMAND
    EXEC_STRING     /opt/sst/bin/netsurf "file:%Arg_1%"
    ICON            Nsurf
    WINDOW_TYPE     NO_STDIO
}
DTEOF

