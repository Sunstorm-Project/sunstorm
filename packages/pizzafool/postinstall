#!/bin/sh
# SSTpzfol postinstall — CDE desktop integration for PizzaFool

DTDIR=/usr/dt/appconfig
TYPES="${DTDIR}/types/C"
ICONS="${DTDIR}/icons/C"

# Create CDE action definition
mkdir -p "${TYPES}" "${ICONS}"
cat > "${TYPES}/pizzafool.dt" << 'DTEOF'
# PizzaFool — Motif/CDE Pizza Ordering Tool
# "I pity the fool who don't order pizza!" — Mr. T
# CDE Action and DataType definitions

ACTION Pizzafool
{
    LABEL           PizzaFool
    TYPE            COMMAND
    EXEC_STRING     /opt/pizzafool/bin/pizzafool
    ICON            Pzfol
    WINDOW_TYPE     NO_STDIO
    DESCRIPTION     Pizza ordering app with Mr. T, inspired by Sun PizzaTool
}
DTEOF

